---
import type { Page, GetStaticPaths } from "astro";
import type { CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/Base.astro";
import PostPreview from "../../components/blog/PostPreviewA.astro";
import Pagination from "../../components/Pagination.astro";
import { getAllPosts, sortMDByDate, sortMDByPinned } from "../../utils";

export const getStaticPaths = (async ({ paginate }) => {
	const allPosts = (await getAllPosts(true)).filter(({ data }) => !data.draft);
	const posts = sortMDByPinned(sortMDByDate(allPosts));
	return paginate(posts, { pageSize: 20 });
}) satisfies GetStaticPaths;

interface Props {
	page: Page<CollectionEntry<"blog">>;
}

const { page } = Astro.props;
const paginationProps = {
	...(page.url.prev && { prevUrl: { url: page.url.prev, text: "← 이전" } }),
	...(page.url.next && { nextUrl: { url: page.url.next, text: "다음 →" } }),
};
---

<BaseLayout title="Writing" description="백엔드, 시스템 소프트웨어와 문제 해결에 관한 글 모음입니다.">
	<header class="mb-12">
		<h1 class="text-3xl font-semibold tracking-tight">Writing</h1>
		<nav class="mt-4 flex gap-4 text-sm text-[var(--theme-muted)]" aria-label="글 분류">
			<a class="hover:text-accent" href="/tags">Tags</a>
			<a class="hover:text-accent" href="/series">Series</a>
			<a class="hover:text-accent" href="/rss.xml">RSS</a>
		</nav>
	</header>

	<ul>
		{page.data.map((post) => <PostPreview post={post} />)}
	</ul>
	<Pagination {...paginationProps} />
</BaseLayout>
