---
import type { MarkdownHeading } from "astro";
import TableOfContentsHeading from "./TableOfContentsHeading.astro";

export interface TocItem extends MarkdownHeading {
	subheadings: TocItem[];
}

const { headings } = Astro.props as { headings: ReadonlyArray<MarkdownHeading> };

function buildToc(items: ReadonlyArray<MarkdownHeading>): TocItem[] {
	const toc: TocItem[] = [];
	const stack: TocItem[] = [];

	for (const item of items) {
		const heading: TocItem = { ...item, subheadings: [] };
		while (stack.length && stack[stack.length - 1].depth >= heading.depth) stack.pop();
		if (stack.length) stack[stack.length - 1].subheadings.push(heading);
		else toc.push(heading);
		stack.push(heading);
	}

	return toc;
}

const toc = buildToc(headings);
---

<details class="not-prose my-8 border-y border-[var(--theme-border)] py-4">
	<summary class="cursor-pointer select-none text-sm font-medium text-[var(--theme-muted)] hover:text-accent">
		목차 <span class="ml-1 font-normal">({headings.length})</span>
	</summary>
	<nav class="mt-4" aria-label="글 목차">
		<ul class="space-y-2 text-sm leading-6 text-[var(--theme-muted)]">
			{toc.map((heading) => <TableOfContentsHeading heading={heading} />)}
		</ul>
	</nav>
</details>
