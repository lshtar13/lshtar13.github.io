---
import { NAV_LINKS, siteConfig } from "../consts";
import ThemeToggle from "./ThemeToggle.astro";

const { pathname } = Astro.url;
---

<header class="mb-14 flex items-center justify-between gap-5 pt-1 sm:mb-20">
	<a class="font-semibold tracking-tight text-textColor hover:text-accent" href="/" aria-label={`${siteConfig.profile.author} home`}>
		{siteConfig.profile.author}
	</a>
	<div class="flex items-center gap-5">
		<nav aria-label="Main navigation">
			<ul class="flex items-center gap-4 text-sm text-[var(--theme-muted)]">
				{NAV_LINKS.map(({ title, path }) => (
					<li>
						<a
							class:list={["hover:text-accent", { "text-textColor": pathname === path || pathname.startsWith(`${path}/`) }]}
							href={path}
							aria-current={pathname === path || pathname.startsWith(`${path}/`) ? "page" : undefined}
						>
							{title}
						</a>
					</li>
				))}
			</ul>
		</nav>
		<ThemeToggle />
	</div>
</header>
