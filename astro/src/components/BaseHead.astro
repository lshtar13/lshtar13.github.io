---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import { siteConfig } from '../consts.ts';

interface Props {
	title: string;
	description: string;
	image?: string;
	type?: 'website' | 'article';
	publishedTime?: string;
	modifiedTime?: string;
	tags?: string[];
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const {
	title,
	description,
	type = 'website',
	publishedTime,
	modifiedTime,
	tags = [],
	image = '/blog-placeholder-1.jpg'
} = Astro.props;
const titleSeparator = "|";
const siteTitle = `${title} ${titleSeparator} ${siteConfig.title}`;
const socialImageURL = new URL(image, Astro.site);
const shouldIndex = !(
	/^\/blog\/\d+\/$/.test(Astro.url.pathname) ||
	(/^\/tags\/.+/.test(Astro.url.pathname)) ||
	(/^\/series\/.+/.test(Astro.url.pathname))
);

const structuredData = type === 'article'
	? {
		'@context': 'https://schema.org',
		'@type': 'BlogPosting',
		headline: title,
		description,
		url: canonicalURL.href,
		mainEntityOfPage: canonicalURL.href,
		image: socialImageURL.href,
		datePublished: publishedTime,
		dateModified: modifiedTime ?? publishedTime,
		inLanguage: siteConfig.lang,
		author: {
			'@type': 'Person',
			name: siteConfig.profile.author,
			url: new URL('/about/', Astro.site).href
		},
		publisher: {
			'@type': 'Person',
			name: siteConfig.profile.author
		},
		keywords: tags.join(', ')
	}
	: {
		'@context': 'https://schema.org',
		'@type': 'WebSite',
		name: siteConfig.title,
		description: siteConfig.description,
		url: new URL('/', Astro.site).href,
		inLanguage: siteConfig.lang
	};
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<meta name="generator" content={Astro.generator} />
<meta name="robots" content={shouldIndex ? 'index, follow' : 'noindex, follow'} />

<!-- Font preloads -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Nanum+Gothic+Coding:wght@400;700&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet">

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{siteTitle}</title>
<meta name="title" content={siteTitle} />
<meta name="description" content={description} />
<meta name="author" content={siteConfig.profile.author} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:site_name" content={siteConfig.title} />
<meta property="og:locale" content="ko_KR" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={socialImageURL} />
{
	type === 'article' && publishedTime && (
		<>
			<meta property="article:author" content={siteConfig.profile.author} />
			<meta property="article:published_time" content={publishedTime} />
			{modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
			{tags.map((tag) => <meta property="article:tag" content={tag} />)}
		</>
	)
}

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={socialImageURL} />

<!-- Structured data -->
<script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
