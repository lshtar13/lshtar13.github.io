---
import { socialLinks } from "../consts.ts";
---

<ul class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-[var(--theme-muted)]" aria-label="소셜 링크">
	{socialLinks.map(({ link, friendlyName }) => (
		<li>
			<a
				class="underline decoration-[var(--theme-border)] underline-offset-4 hover:text-accent hover:decoration-accent"
				href={link}
				target={link.startsWith("http") ? "_blank" : undefined}
				rel={link.startsWith("http") ? "noopener noreferrer" : undefined}
			>
				{friendlyName}
			</a>
		</li>
	))}
</ul>
