---
import { siteConfig } from "../consts.ts";
import SocialMediaLinks from "./SocialMediaLinks.astro";

const year = new Date().getFullYear();
---

<footer class="mt-auto flex flex-col gap-3 border-t border-[var(--theme-border)] pb-10 pt-8 text-sm text-[var(--theme-muted)] sm:flex-row sm:items-center sm:justify-between">
	<p>&copy; {year} {siteConfig.profile.author}</p>
	<SocialMediaLinks />
</footer>
