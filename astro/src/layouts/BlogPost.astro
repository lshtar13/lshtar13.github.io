---
import type { CollectionEntry } from "astro:content";
import Layout from "./Sidebar.astro";
import FormattedDate from "../components/FormattedDate.astro";
import TableOfContents from "../components/TableOfContents.astro";
import CopyBtn from "../components/CopyBtn.astro";

interface Props {
	post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const {
	data: { title, description, pubDate, updatedDate, heroImage, ogImage, tags, series, draft },
} = post;

const { headings, remarkPluginFrontmatter } = post.render && await post.render();
const { minutesRead } = remarkPluginFrontmatter;
const socialImage = ogImage ?? heroImage?.src ?? "/blog-placeholder-1.jpg";
const publishedTime = pubDate.toISOString();
const modifiedTime = updatedDate?.toISOString();
const dateTimeOptions: Intl.DateTimeFormatOptions = {
	year: "numeric",
	month: "short",
	day: "numeric",
};
---

<Layout
	title={title}
	description={description}
	image={socialImage}
	type="article"
	publishedTime={publishedTime}
	modifiedTime={modifiedTime}
	tags={tags}
>
	<article class="prose prose-cody max-w-none dark:prose-invert">
		<header class="not-prose mb-12">
			{series && (
				<p class="mb-4 text-sm text-[var(--theme-muted)]">
					<a class="hover:text-accent" href={`/series/${series}`}>{series}</a>
				</p>
			)}

			<div class="flex items-start gap-3">
				<h1 class="text-3xl font-semibold leading-tight tracking-tight text-textColor sm:text-4xl">{title}</h1>
				{draft && <span class="mt-2 text-xs text-[var(--theme-muted)]">Draft</span>}
			</div>

			<div class="mt-4 flex flex-wrap items-center gap-x-2 text-sm text-[var(--theme-muted)]">
				<FormattedDate date={pubDate} dateTimeOptions={dateTimeOptions} />
				<span aria-hidden="true">·</span>
				<span>{minutesRead}</span>
				{updatedDate && (
					<>
						<span aria-hidden="true">·</span>
						<span>수정 <FormattedDate date={updatedDate} dateTimeOptions={dateTimeOptions} /></span>
					</>
				)}
			</div>

			{tags && tags.length > 0 && (
				<ul class="mt-3 flex flex-wrap gap-x-3 gap-y-1 text-sm text-[var(--theme-muted)]" aria-label="태그">
					{tags.map((tag) => (
						<li><a class="hover:text-accent" href={`/tags/${tag}`}>{tag}</a></li>
					))}
				</ul>
			)}

			{heroImage && (
				<img src={heroImage.src} alt={heroImage.alt ?? ""} class="mt-8 w-full" />
			)}
		</header>

		{headings.length >= 3 && <TableOfContents headings={headings} />}

		<div class="article-body">
			<slot />
		</div>

		<div class="not-prose mt-20 border-t border-[var(--theme-border)] pt-10">
			<script is:inline src="https://giscus.app/client.js"
				data-repo="lshtar13/giscus"
				data-repo-id="R_kgDONcgyxg"
				data-category="General"
				data-category-id="DIC_kwDONcgyxs4ClJ87"
				data-mapping="pathname"
				data-strict="0"
				data-reactions-enabled="1"
				data-emit-metadata="0"
				data-input-position="bottom"
				data-theme="preferred_color_scheme"
				data-lang="ko"
				crossorigin="anonymous"
				async>
			</script>
		</div>
	</article>
</Layout>

<CopyBtn />
