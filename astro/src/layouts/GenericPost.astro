---
import Layout from "./Sidebar.astro";
import TableOfContents from "../components/TableOfContents.astro";

const { frontmatter: { title, description }, headings } = Astro.props;
---

<Layout title={title} description={description}>
	<article class="prose prose-cody max-w-none dark:prose-invert">
		{headings.length >= 3 && <TableOfContents headings={headings} />}
		<slot />
	</article>
</Layout>
